[
  {
    "id": "mawiblah-dont-disturn-threshold",
    "title": "Dont disturb threshold",
    "description": "The threshold/delta between emails to one subcriber. If the threshold is not reached, the email will not be sent. We dont want to bother subscribers that did recieve email aready lately.",
    "fields": [
      {
        "id": "mawiblah-dont-disturb-threshold",
        "title": "Time between the subscriber is contacred again (in seconds)",
        "type": "text",
        "value": "",
        "placeholder": "2592000",
        "default_value": "2592000"
      }
    ]
  },
  {
    "id": "time-between-emails",
    "title": "Time between emails (in seconds)",
    "description": "Set the time between emails. If to send out with some delay.",
    "fields": [
      {
        "id": "mawiblah-time-between-emails",
        "title": "Time between emails (in seconds)",
        "type": "text",
        "value": "",
        "placeholder": "1",
        "default_value": "1"
      }
    ]
  },
  {
    "id": "debug",
    "title": "Logging",
    "description": "Enable file-based logging to record plugin actions to daily log files. Logs are stored in {uploads}/gae-logs/mawiblah-YYYY-MM-DD.log and can be viewed under Mawiblah → Logs.",
    "fields": [
      {
        "id": "mawiblah-debug",
        "title": "File logging",
        "type": "select",
        "value": "",
        "placeholder": "",
        "default_value": "disabled",
        "options": [
          {
            "value": "disabled",
            "title": "Disabled"
          },
          {
            "value": "enable-file-log",
            "title": "Enable - file log"
          }
        ]
      },
      {
        "id": "mawiblah-debug-ip",
        "title": "Restrict output by ip (comma separated)",
        "type": "text",
        "value": "",
        "placeholder": "127.0.0.1",
        "default_value": ""
      },
      {
        "id": "mawiblah-dont-send-emails",
        "title": "Can disable actual email sending",
        "type": "select",
        "value": "",
        "placeholder": "",
        "default_value": "disabled",
        "options": [
          {
            "value": "send-emails",
            "title": "Send emails"
          },
          {
            "value": "dont-send-emails",
            "title": "Dont send emails"
          }
        ]
      }
    ]
  },
  {
    "id": "mawiblah-failing-email",
    "title": "Failing Email",
    "description": "If sending to a subscriber fails this many times across all campaigns, they are automatically added to the 'Failing Email' audience and skipped in future sends.",
    "fields": [
      {
        "id": "mawiblah-failing-email-threshold",
        "title": "Failure threshold (number of failed sends before marking as Failing Email)",
        "type": "text",
        "value": "",
        "placeholder": "3",
        "default_value": "3"
      }
    ]
  },
  {
    "id": "mawiblah-recaptcha",
    "title": "reCAPTCHA v3 (Subscription Form)",
    "description": "Optional Google reCAPTCHA v3 protection for the subscription form. Leave disabled to rely on honeypot only. Get your keys at https://www.google.com/recaptcha/admin/",
    "fields": [
      {
        "id": "mawiblah-recaptcha-enabled",
        "title": "Enable reCAPTCHA v3",
        "type": "select",
        "value": "",
        "placeholder": "",
        "default_value": "disabled",
        "options": [
          {
            "value": "disabled",
            "title": "Disabled"
          },
          {
            "value": "enabled",
            "title": "Enabled"
          }
        ]
      },
      {
        "id": "mawiblah-recaptcha-site-key",
        "title": "Site Key (public)",
        "type": "text",
        "value": "",
        "placeholder": "6Lc...",
        "default_value": ""
      },
      {
        "id": "mawiblah-recaptcha-secret-key",
        "title": "Secret Key (private, never expose publicly)",
        "type": "text",
        "value": "",
        "placeholder": "6Lc...",
        "default_value": ""
      }
    ]
  },
  {
    "id": "mawiblah-open-tracking",
    "title": "Email Open Tracking",
    "description": "Embeds a 1×1 tracking pixel in outgoing emails. Requires server-side configuration (nginx must serve the pixel URL and execute PHP). When enabled, unique opens are recorded per subscriber per campaign. Note: inform subscribers in your privacy policy.",
    "fields": [
      {
        "id": "mawiblah-open-tracking-enabled",
        "title": "Enable open tracking",
        "type": "select",
        "value": "",
        "placeholder": "",
        "default_value": "disabled",
        "options": [
          {
            "value": "disabled",
            "title": "Disabled"
          },
          {
            "value": "enabled",
            "title": "Enabled"
          }
        ]
      }
    ]
  },
  {
    "id": "mawiblah-background-send",
    "title": "Background Send (WP Cron)",
    "description": "Settings for background campaign sending via WP Cron. Campaigns can be sent in the background so you can close the browser tab.",
    "fields": [
      {
        "id": "mawiblah-background-batch-size",
        "title": "Subscribers per cron batch",
        "type": "number",
        "value": "",
        "placeholder": "100",
        "default_value": "100"
      }
    ]
  },
  {
    "id": "mawiblah-scheduler",
    "title": "Scheduler",
    "description": "How often WP Cron checks whether a scheduled campaign is due. Lower values mean sends fire closer to the configured time, but generate more cron runs.",
    "fields": [
      {
        "id": "mawiblah-scheduler-interval",
        "title": "Scheduler check interval",
        "type": "select",
        "value": "",
        "placeholder": "",
        "default_value": "3600",
        "options": [
          { "value": "60",    "title": "Every 1 minute" },
          { "value": "300",   "title": "Every 5 minutes" },
          { "value": "600",   "title": "Every 10 minutes" },
          { "value": "900",   "title": "Every 15 minutes" },
          { "value": "1800",  "title": "Every 30 minutes" },
          { "value": "3600",  "title": "Every 1 hour" },
          { "value": "7200",  "title": "Every 2 hours" },
          { "value": "14400", "title": "Every 4 hours" },
          { "value": "28800", "title": "Every 8 hours" },
          { "value": "43200", "title": "Every 12 hours" },
          { "value": "86400", "title": "Once per day" }
        ]
      }
    ]
  }
]
